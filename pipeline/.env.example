# Pipeline runs WITHOUT any of these (demo mode). Add to go live.
ANTHROPIC_API_KEY=            # fresh scripts + strategy
GEMINI_API_KEY=               # real visuals (aistudio.google.com, free tier)
NANO_BANANA_MODEL=gemini-2.5-flash-image
ELEVENLABS_API_KEY=           # premium voice (optional)

SUPABASE_URL=                 # board + ledger + media storage (same project as web/)
SUPABASE_SERVICE_KEY=         # service_role key — server only, never in web/

IG_USER_ID=                   # after Meta app review
IG_ACCESS_TOKEN=
YT_TOKEN_JSON=yt_token.json   # YouTube OAuth token file

TENANT_ID=me
BATCH_SIZE=3
DAILY_BUDGET_USD=3.0
KILL_SWITCH=0
CTA_LINE=Follow for one AI move a day.

# --- optional fine-tuning (safe defaults built in) ---
CLAUDE_MODEL=claude-sonnet-4-5
EDGE_VOICE=en-US-ChristopherNeural
ELEVEN_VOICE_ID=
GOOGLE_API_KEY=               # alias for GEMINI_API_KEY, either works

# --- strategy: competitor outlier watch (optional, zero-key) ---
# YouTube channel IDs of pages in your niche, comma-separated.
# Find an ID: open the channel page -> view source -> search "channel_id".
COMPETITOR_CHANNELS=

# --- marketing: community + weekly digest (all optional) ---
COMMUNITY_AUTOREPLY=0          # 1 = post AI replies automatically (needs IG keys); 0 = draft for Studio review
RESEND_API_KEY=                # resend.com free tier -> weekly digest lands in your inbox
DIGEST_EMAIL=
