# --- Supabase (same project as the pipeline) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=      # server-only: webhook + waitlist writes

# --- Stripe (test mode first). If Stripe unsupported in your country, see docs/DEPLOY.md §Payments.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_YT=
STRIPE_PRICE_ECOM=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Studio (your control room at /studio) ---
ADMIN_EMAILS=you@example.com   # comma-separated; these accounts see the board + kill switch
TENANT_ID=me
